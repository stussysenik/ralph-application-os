{
  "name": "ralph-application-os",
  "private": true,
  "version": "0.0.0-development",
  "description": "Semantic application OS for building provable evolving software from intent.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "tsc -b --force tsconfig.json",
    "typecheck": "tsc -b tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:sync": "node scripts/sync-docs.mjs",
    "demo": "pnpm build && node packages/ralph-cli/dist/index.js",
    "swarm:demo": "pnpm build && node packages/ralph-cli/dist/index.js swarm",
    "ralph:artifact": "pnpm build && node packages/ralph-cli/dist/index.js artifact",
    "ralph:ideate": "pnpm build && node packages/ralph-cli/dist/index.js ideate",
    "ralph:interview": "pnpm build && node packages/ralph-cli/dist/index.js interview",
    "ralph:draft": "pnpm build && node packages/ralph-cli/dist/index.js draft",
    "ralph:correction:new": "pnpm build && node packages/ralph-cli/dist/index.js correction:new",
    "ralph:correction:promote": "pnpm build && node packages/ralph-cli/dist/index.js correction:promote",
    "ralph:model:diff": "pnpm build && node packages/ralph-cli/dist/index.js model:diff",
    "ralph:model:merge": "pnpm build && node packages/ralph-cli/dist/index.js model:merge",
    "ralph:model:patch": "pnpm build && node packages/ralph-cli/dist/index.js model:patch",
    "ralph:loop": "pnpm build && node packages/ralph-cli/dist/index.js loop",
    "ralph:team": "pnpm build && node packages/ralph-cli/dist/index.js team",
    "ralph:job:new": "pnpm build && node packages/ralph-cli/dist/index.js job:new",
    "ralph:job:from-draft": "pnpm build && node packages/ralph-cli/dist/index.js job:from-draft",
    "ralph:job:validate": "pnpm build && node packages/ralph-cli/dist/index.js job:validate",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run",
    "spec:validate": "openspec validate define-ralph-application-os && openspec validate shift-to-internal-builders && openspec validate add-job-runtime-and-ledger && openspec validate add-interview-loop && openspec validate add-draft-synthesis && openspec validate add-draft-promotion && openspec validate add-semantic-model-diff && openspec validate add-semantic-model-patch && openspec validate add-semantic-model-merge && openspec validate add-replay-proofs-and-runtime-artifacts && openspec validate add-local-interactive-runtime && openspec validate add-cross-domain-ideation-briefs && openspec validate add-relation-aware-interview-synthesis && openspec validate add-engineering-handoff-artifacts && openspec validate add-ideation-improvement-opportunities && openspec validate add-correction-memory && openspec validate add-correction-harvest-promotion",
    "prompt": "cat START_PROMPT.md"
  },
  "devDependencies": {
    "@fission-ai/openspec": "^1.2.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^24.6.0",
    "semantic-release": "^24.2.7",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
