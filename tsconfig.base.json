{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@ralph/semantic-kernel": ["packages/semantic-kernel/src/index.ts"],
      "@ralph/internal-builders": ["packages/internal-builders/src/index.ts"],
      "@ralph/proof-harness": ["packages/proof-harness/src/index.ts"],
      "@ralph/agent-swarm": ["packages/agent-swarm/src/index.ts"]
    },
    "outDir": "dist"
  }
}
